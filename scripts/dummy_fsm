#!/usr/bin/env python

from cartesian_interface.pyci_all import *
from states import (
    MoveToTargetFromCfg,
    FollowWaypointsFromCfg,
    RunDemo,
    SetPosturalFromCfg,
)
import rospy
import rospkg
import smach
import tf2_ros


def no_log(msg):
    pass


def main():
    rospy.init_node("smach_example_state_machine")
    rospack = rospkg.RosPack()

    # Set up tf2 listener
    tf_buffer = tf2_ros.Buffer()
    tf2_ros.TransformListener(tf_buffer)

    # Init CartesI/O client
    client = pyci.CartesianInterfaceRos()

    # Wait for tf listener
    rospy.sleep(1)

    smach.set_loggers(smach.loginfo, smach.logwarn, no_log, smach.logerr)

    # Create a SMACH state machine
    sm = smach.StateMachine(outcomes=["fsm_success", "fsm_fail"])

    # Define userdata for the state machine
    sm.userdata.client = client
    sm.userdata.tf_buffer = tf_buffer
    sm.userdata.config_path = rospack.get_path("fsm_cartesio") + "/config/dummy.yaml"
    sm.userdata.left_motion_tag = "left_waypoints"
    sm.userdata.right_motion_tag = "right_waypoints"
    sm.userdata.base_motion_tag = "mobile_pose"

    sm.userdata.demo_folder = rospack.get_path("fsm_cartesio") + "/config/demo"
    sm.userdata.dummy_demo_right = "dummy_demo_right"
    sm.userdata.dummy_demo_left = "dummy_demo_left"

    sm.userdata.posture_home = "posture_home"
    sm.userdata.go_to_posture = False

    # Open the state machine container
    with sm:
        smach.StateMachine.add(
            "DEMO_RIGHT",
            RunDemo(),
            transitions={"success": "DEMO_LEFT", "fail": "fsm_fail"},
            remapping={
                "client": "client",
                "tf_buffer": "tf_buffer",
                "config_path": "config_path",
                "demo_folder": "demo_folder",
                "tag": "dummy_demo_right",
            },
        )
        smach.StateMachine.add(
            "DEMO_LEFT",
            RunDemo(),
            transitions={"success": "MOVE_LEFT", "fail": "fsm_fail"},
            remapping={
                "client": "client",
                "tf_buffer": "tf_buffer",
                "config_path": "config_path",
                "demo_folder": "demo_folder",
                "tag": "dummy_demo_left",
            },
        )

        smach.StateMachine.add(
            "MOVE_LEFT",
            FollowWaypointsFromCfg(),
            transitions={"success": "MOVE_RIGHT", "fail": "fsm_fail"},
            remapping={
                "client": "client",
                "tf_buffer": "tf_buffer",
                "config_path": "config_path",
                "tag": "left_motion_tag",
            },
        )

        smach.StateMachine.add(
            "MOVE_RIGHT",
            FollowWaypointsFromCfg(),
            transitions={"success": "MOVE_BASE", "fail": "fsm_fail"},
            remapping={
                "client": "client",
                "tf_buffer": "tf_buffer",
                "config_path": "config_path",
                "tag": "right_motion_tag",
            },
        )

        smach.StateMachine.add(
            "MOVE_BASE",
            MoveToTargetFromCfg(),
            transitions={"success": "RESET_JOINTS", "fail": "fsm_fail"},
            remapping={
                "client": "client",
                "tf_buffer": "tf_buffer",
                "config_path": "config_path",
                "tag": "base_motion_tag",
            },
        )

        smach.StateMachine.add(
            "RESET_JOINTS",
            SetPosturalFromCfg(postural_lambda=0.005, timeout=6),
            transitions={"success": "fsm_success", "fail": "fsm_fail"},
            remapping={
                "client": "client",
                "config_path": "config_path",
                "tag": "posture_home",
                "go_to": "go_to_posture",
            },
        )

    # Execute the state machine
    outcome = sm.execute()


if __name__ == "__main__":
    main()
